{
  "name": "@scavio/mcp-server",
  "version": "0.1.1",
  "mcpName": "io.github.scavio-ai/scavio-mcp",
  "description": "MCP server connecting AI agents to Google, YouTube, Amazon, Walmart, TikTok, and Reddit. 21 tools for web search, product lookup, video discovery, and social media analysis.",
  "type": "module",
  "license": "MIT",
  "author": "Scavio",
  "homepage": "https://github.com/scavio-ai/scavio-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scavio-ai/scavio-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/scavio-ai/scavio-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scavio",
    "google",
    "youtube",
    "amazon",
    "walmart",
    "tiktok",
    "reddit",
    "web-search"
  ],
  "bin": {
    "scavio-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
